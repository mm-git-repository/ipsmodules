{
    "elements": [
        {
            "type": "Label",
            "name": "ModuleVersionInfo",
            "caption": "Installierte Modulversion"
        },
        {
            "type": "CheckBox",
            "name": "Active",
            "caption": "Aktiv"
        },
        {
            "type": "Select",
            "name": "DataSource",
            "caption": "Datenquelle",
            "options": [
                {
                    "label": "Nur LAN",
                    "value": "lan"
                },
                {
                    "label": "Nur Cloud",
                    "value": "cloud"
                },
                {
                    "label": "LAN, sonst Cloud",
                    "value": "lan_then_cloud"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Tuya-Kopplung (einmalig)",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "name": "CloudCouplingStatus",
                    "caption": "Status: nicht verbunden"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "CloudUserCode",
                    "caption": "User Code (Tuya Smart → Ich → Einstellungen → Konto und Sicherheit)"
                },
                {
                    "type": "Select",
                    "name": "CloudSelectedDevice",
                    "caption": "Gerät aus Cloud-Liste",
                    "options": [
                        {
                            "label": "(zuerst QR-Login und Geräteliste laden)",
                            "value": ""
                        }
                    ]
                },
                {
                    "type": "CheckBox",
                    "name": "KeepCloudSession",
                    "caption": "Cloud-Session nach Übernahme behalten (für Cloud-Fallback)"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Tuya IoT Cloud (alle Messwerte: pH/ORP/EC)",
            "expanded": false,
            "items": [
                {
                    "type": "ValidationTextBox",
                    "name": "OpenApiAccessId",
                    "caption": "IoT Access ID (iot.tuya.com → Cloud → Entwicklung)"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "OpenApiAccessSecret",
                    "caption": "IoT Access Secret"
                },
                {
                    "type": "Select",
                    "name": "OpenApiRegion",
                    "caption": "IoT Rechenzentrum (wie Tuya-App)",
                    "options": [
                        {
                            "label": "EU (West)",
                            "value": "eu"
                        },
                        {
                            "label": "USA",
                            "value": "us"
                        },
                        {
                            "label": "China",
                            "value": "cn"
                        },
                        {
                            "label": "Indien",
                            "value": "in"
                        }
                    ]
                }
            ]
        },
        {
            "type": "ValidationTextBox",
            "name": "Host",
            "caption": "Geräte-IP (LAN)"
        },
        {
            "type": "ValidationTextBox",
            "name": "DeviceId",
            "caption": "Tuya Device ID"
        },
        {
            "type": "ValidationTextBox",
            "name": "LocalKey",
            "caption": "Tuya Local Key (Klartext)"
        },
        {
            "type": "Select",
            "name": "ProtocolVersion",
            "caption": "Tuya-Protokollversion",
            "options": [
                {
                    "label": "3.2",
                    "value": "3.2"
                },
                {
                    "label": "3.3",
                    "value": "3.3"
                },
                {
                    "label": "3.4",
                    "value": "3.4"
                },
                {
                    "label": "3.5",
                    "value": "3.5"
                }
            ]
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateIntervalSeconds",
            "caption": "Aktualisierungsintervall (Sekunden, mindestens 15)",
            "digits": 0,
            "minimum": 15
        },
        {
            "type": "ValidationTextBox",
            "name": "DpMapping",
            "caption": "DP-Mapping (JSON, Standard: PH-W218 / 8-in-1)"
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "QR-Code anzeigen",
            "onClick": "TWQT_CloudShowQr($id);"
        },
        {
            "type": "Button",
            "caption": "Auf Anmeldung warten",
            "onClick": "echo TWQT_CloudPollLogin($id);"
        },
        {
            "type": "Button",
            "caption": "Gerät übernehmen & speichern",
            "onClick": "echo TWQT_CloudApplyDevice($id);"
        },
        {
            "type": "Button",
            "caption": "LAN-Scan (IP)",
            "onClick": "echo TWQT_LanDiscover($id);"
        },
        {
            "type": "Button",
            "caption": "IoT-Cloud testen",
            "onClick": "echo TWQT_CloudOpenApiTest($id);"
        },
        {
            "type": "Button",
            "caption": "Cloud-Session beenden",
            "onClick": "echo TWQT_CloudLogout($id);"
        },
        {
            "type": "Button",
            "caption": "Jetzt aktualisieren",
            "onClick": "echo TWQT_RefreshFeedback($id);"
        },
        {
            "type": "Label",
            "caption": "Kopplung: User Code → QR-Code anzeigen → scannen → Auf Anmeldung warten → Gerät wählen → „Gerät übernehmen & speichern“. Local Key erscheint danach im Feld oben. Für Cloud-Fallback: „Cloud-Session behalten“ aktiv lassen."
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Inaktiv"
        },
        {
            "code": 201,
            "icon": "error",
            "caption": "Konfiguration unvollständig"
        },
        {
            "code": 202,
            "icon": "error",
            "caption": "Gerät nicht erreichbar"
        }
    ]
}
