{
    "elements": [
        {
            "type": "Label",
            "caption": "IPS-Variablen und Pixoo-Display nutzen dasselbe Intervall (Feld unten, ein Update-Timer). Quellvariablen-Änderungen werden ebenfalls auf dieses Intervall begrenzt. SMARD-Preis separat alle 15 Min."
        },
        {
            "type": "Label",
            "caption": "Vorschau der Pixoo-Darstellung (schematisch, 192×192 px ≈ 3× 64er Raster). Beispielwerte im Bild: 500 W Verbrauch, 1000 W Erzeugung, 500 W Netzbezug (rot), 0,12 € SMARD (grün). Auf dem Pixoo gelten Ihre Messdaten."
        },
        {
            "type": "Image",
            "caption": "Vorschau",
            "image": "data:image/png;base64,",
            "width": "192px",
            "center": true
        },
        {
            "type": "CheckBox",
            "name": "Active",
            "caption": "Aktiv"
        },
        {
            "type": "ValidationTextBox",
            "name": "PixooIp",
            "caption": "Pixoo IP-Adresse"
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateIntervalSeconds",
            "caption": "Aktualisierung Werte + Pixoo-Display (Sekunden, mindestens 5; ein gemeinsamer Zyklus pro Intervall)",
            "digits": 0,
            "minimum": 5
        },
        {
            "type": "CheckBox",
            "name": "PixooHourlyReinit",
            "caption": "Display stündlich auffrischen (Helligkeit + Texte; leicht — gegen Zurückschalten auf Ziffernblatt, ohne schweres GIF-Init)"
        },
        {
            "type": "ExpansionPanel",
            "caption": "Pixoo: Helligkeit (Tag & Nacht)",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "caption": "Taghelligkeit gilt immer; Nachthelligkeit optional nach Uhrzeit des IP-Symcon-Servers (Felder unten)."
                },
                {
                    "type": "NumberSpinner",
                    "name": "DefaultBrightness",
                    "caption": "Helligkeit Tag (0–100)",
                    "digits": 0
                },
                {
                    "type": "Label",
                    "caption": "Zeitbezug: Uhrzeit des IP-Symcon-Servers. „Nacht“ von Stunde (inkl.) bis Stunde (exkl.); über Mitternacht z. B. 22 → 6."
                },
                {
                    "type": "CheckBox",
                    "name": "PixooNightBrightnessUse",
                    "caption": "Nachthelligkeit verwenden"
                },
                {
                    "type": "NumberSpinner",
                    "name": "PixooNightBrightness",
                    "caption": "Helligkeit Nacht (0–100)",
                    "digits": 0
                },
                {
                    "type": "NumberSpinner",
                    "name": "PixooNightHourFrom",
                    "caption": "Nacht ab Stunde (0–23)",
                    "digits": 0
                },
                {
                    "type": "NumberSpinner",
                    "name": "PixooNightHourTo",
                    "caption": "Nacht bis Stunde (0–23, exkl.)",
                    "digits": 0
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "SMARD Strompreis",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "caption": "Day-Ahead Börsenpreis DE/LU (Filter 4169, Viertelstunden), www.smard.de, Abholung alle 15 Min. Wert EUR/MWh → Anzeige als Zahl in € (÷1000). Rechts unten: gleiche Schriftgröße wie die Netz-Watt-Zahl (Font 2, Zeilenhöhe 16). Positiver Wert = grün, sonst rot."
                },
                {
                    "type": "Label",
                    "caption": "Optionaler Zeitstempel: festes Format Stunde:Minute (24 h, z. B. 14:30), rechts in derselben Zeile wie das Label „NETZ“; gleiche Ziffern-Schrift wie die Watt-Werte (Font 2), kompakte Zeilenhöhe."
                },
                {
                    "type": "CheckBox",
                    "name": "PixooShowSmardPrice",
                    "caption": "SMARD-Preis auf Pixoo anzeigen"
                },
                {
                    "type": "CheckBox",
                    "name": "PixooSmardShowUnit",
                    "caption": "Preis mit „€“ anhängen"
                },
                {
                    "type": "CheckBox",
                    "name": "PixooSmardShowTime",
                    "caption": "Zeitstempel der SMARD-Daten neben „NETZ“ (rechts)"
                },
                {
                    "type": "Label",
                    "caption": "Hinweis: Es wird der Beginn der Viertelstunde der zuletzt vom Modul geladenen SMARD-Daten angezeigt (Format HH:MM) — nicht die laufende Uhrzeit."
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Home Manager 2 (Real Power ±)",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "caption": "Real Power + = Netzbezug, Real Power − = Netzeinspeisung (W). String- oder Float-/Integer-Variablen. Netz = Bezug − Einspeisung."
                },
                {
                    "type": "SelectVariable",
                    "name": "HmRealPowerPlusVar",
                    "caption": "Variable: Real Power + (Netzbezug, W)"
                },
                {
                    "type": "SelectVariable",
                    "name": "HmRealPowerMinusVar",
                    "caption": "Variable: Real Power − (Netzeinspeisung, W)"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Wechselrichter 1 (2 Variablen)",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "caption": "Zwei Variablen pro WR (Integer, Float oder String mit Zahl). Erzeugung = Summe aller vier Werte (je Wert ≥ 0). Bei Fehler 201: Meldungsarchiv der Instanz prüfen (SendDebug „Konfiguration“)."
                },
                {
                    "type": "SelectVariable",
                    "name": "Wr1String1Var",
                    "caption": "Variable 1 (Leistung W)"
                },
                {
                    "type": "SelectVariable",
                    "name": "Wr1String2Var",
                    "caption": "Variable 2 (Leistung W)"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Wechselrichter 2 (2 Variablen)",
            "expanded": false,
            "items": [
                {
                    "type": "SelectVariable",
                    "name": "Wr2String1Var",
                    "caption": "Variable 1 (Leistung W)"
                },
                {
                    "type": "SelectVariable",
                    "name": "Wr2String2Var",
                    "caption": "Variable 2 (Leistung W)"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "SMARD-Preis laden",
            "onClick": "echo SMAPX_SmardLoadActionFeedback($id);"
        },
        {
            "type": "Button",
            "caption": "Jetzt aktualisieren (Werte + Pixoo)",
            "onClick": "SMAPX_Refresh($id); echo 'OK';"
        },
        {
            "type": "Button",
            "caption": "Display neu initialisieren",
            "onClick": "SMAPX_HeavyReinitDisplay($id); echo 'OK';"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Inaktiv"
        },
        {
            "code": 201,
            "icon": "error",
            "caption": "Konfiguration ungültig (alle sechs Variablen prüfen)"
        }
    ]
}
